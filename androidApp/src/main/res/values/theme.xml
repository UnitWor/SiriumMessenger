<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Sirium.NoActionBar" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Статус бар -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>

        <!-- Навигационный бар -->
        <item name="android:navigationBarColor">@android:color/white</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="29">true</item>

        <!-- Фон окна -->
        <item name="android:windowBackground">@android:color/white</item>

        <!-- Убираем ActionBar явно -->
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>

        <!-- Анимации -->
        <item name="android:windowAnimationStyle">@android:style/Animation.Activity</item>

        <!-- Цвета для элементов (если используются не Compose) -->
        <item name="android:colorPrimary">@color/purple_500</item>
        <item name="android:colorPrimaryDark">@color/purple_700</item>
        <item name="android:colorAccent">@color/teal_200</item>
    </style>

</resources>